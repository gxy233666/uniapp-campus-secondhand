{
	"bsonType": "object",
	"required": ["username", "phone"],
	"permission": {
		"read": true,
		"create": true,
		"update": true,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "用户ID"
		},
		"username": {
			"bsonType": "string",
			"title": "用户名",
			"trim": "both"
		},
		"phone": {
			"bsonType": "string",
			"title": "手机号",
			"trim": "both"
		},
		"email": {
			"bsonType": "string",
			"title": "邮箱",
			"trim": "both"
		},
		"password_hash": {
			"bsonType": "string",
			"title": "密码哈希"
		},
		"password_salt": {
			"bsonType": "string",
			"title": "密码盐"
		},
		"avatar": {
			"bsonType": "string",
			"title": "头像地址",
			"trim": "both"
		},
		"created_at": {
			"bsonType": "number",
			"title": "创建时间"
		},
		"updated_at": {
			"bsonType": "number",
			"title": "更新时间"
		}
	}
}