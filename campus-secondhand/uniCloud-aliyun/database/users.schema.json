{
	"bsonType": "object",
	"required": ["username", "phone"],
	"permission": {
		"read": true,
		"create": true,
		"update": true,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "用户ID"
		},
		"username": {
			"bsonType": "string",
			"title": "用户名",
			"trim": "both"
		},
		"phone": {
			"bsonType": "string",
			"title": "联系方式",
			"trim": "both"
		},
		"avatar": {
			"bsonType": "string",
			"title": "头像地址",
			"trim": "both"
		},
		"created_at": {
			"bsonType": "timestamp",
			"title": "创建时间"
		}
	}
}
